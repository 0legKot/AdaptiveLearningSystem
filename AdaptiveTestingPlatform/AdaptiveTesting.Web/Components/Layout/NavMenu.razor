@using AdaptiveTesting.Infrastructure.Services
@implements IDisposable
@inject UserSessionService Session
@inject NavigationManager Nav
@rendermode InteractiveServer

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="" style="white-space: normal; font-size: 1rem; line-height: 1.2; overflow-wrap: break-word;">
            @if (Session.IsTeacher) {
                <span>👨‍🏫 Teacher Mode</span>
            } else if (Session.CurrentUser != null) {
                <span>👨‍🎓 @Session.CurrentUser.FullName</span>
            } else {
                <span>🎓 Adaptive Testing</span>
            }
        </a>

        <button title="Navigation menu" class="navbar-toggler">
            <span class="navbar-toggler-icon"></span>
        </button>
    </div>
</div>

<div class="@NavMenuCssClass">
    <nav class="flex-column">

        @if (Session.CurrentUser == null) {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                    <span class="bi bi-box-arrow-in-right" aria-hidden="true"></span> Вхід
                </NavLink>
            </div>
        } else if (Session.IsTeacher) {
            <div class="nav-item px-3 mt-3">
                <span class="text-light small text-uppercase fw-bold ms-3">Admin Zone</span>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="teacher/monitor">
                    <span class="bi bi-speedometer2" aria-hidden="true"></span> Live Моніторинг
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="teacher/mining">
                    <span class="bi bi-cpu" aria-hidden="true"></span> Data Mining
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="teacher/quality">
                    <span class="bi bi-check-circle" aria-hidden="true"></span> Question quality
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="teacher/analytics-selector">
                    <span class="bi bi-check-circle" aria-hidden="true"></span> Student clustering
                </NavLink>
            </div>
        } else {
            <div class="nav-item px-3 mt-3">
                <span class="text-light small text-uppercase fw-bold ms-3">Student Zone</span>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="@($"/exam/{Session.CurrentUser.Id}")">
                    <span class="bi bi-pencil-square" aria-hidden="true"></span> Пройти Тест
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="@($"/dashboard/{Session.CurrentUser.Id}")">
                    <span class="bi bi-graph-up" aria-hidden="true"></span> Моя Аналітика
                </NavLink>
            </div>
        }

        @if (Session.CurrentUser != null) {
            <div class="nav-item px-3 mt-auto pt-3 border-top border-secondary">
                <button class="nav-link btn btn-link text-start text-danger" @onclick="Logout">
                    <span class="bi bi-box-arrow-left" aria-hidden="true"></span> Вихід
                </button>
            </div>
        }
    </nav>
</div>

@code {
    private bool collapseNavMenu = false;
    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    protected override void OnInitialized() {
        Session.OnChange += StateHasChanged;
    }

    public void Dispose() {
        Session.OnChange -= StateHasChanged;
    }

    private void Logout() {
        Session.Logout();
        Nav.NavigateTo("/");
    }
}