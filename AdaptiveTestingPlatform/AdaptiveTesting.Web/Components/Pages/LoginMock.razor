@page "/"
@using AdaptiveTesting.Domain.Entities
@using AdaptiveTesting.Infrastructure.Persistence
@using Microsoft.EntityFrameworkCore
@inject AppDbContext Db
@inject NavigationManager Nav
@rendermode InteractiveServer 

<div class="container mt-5" style="max-width: 800px;">
    <RadzenCard>
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h3>🔐 Вхід у систему (Demo)</h3>
                <p class="text-muted mb-0">Симуляція входу під різними ролями.</p>
            </div>

            <RadzenButton Text="Кабінет Викладача" Icon="school"
                          ButtonStyle="ButtonStyle.Secondary"
                          Click="@(() => Nav.NavigateTo("/teacher/monitor"))" />
        </div>
        
        <RadzenDataGrid Data="@users" TItem="User" AllowPaging="true" PageSize="5" AllowSorting="true">
            <Columns>
                <RadzenDataGridColumn Property="FullName" Title="Ім'я студента" />
                <RadzenDataGridColumn Property="Role" Title="Роль (Ground Truth)" Width="150px">
                    <Template Context="user">
                        @if(user.ClusterLabel == 0) { <span class="badge bg-danger">Cheater (Simulated)</span> }
                        else if(user.ClusterLabel == 1) { <span class="badge bg-warning text-dark">Junior</span> }
                        else { <span class="badge bg-success">Senior</span> }
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn Title="Дія" Sortable="false" TextAlign="TextAlign.Center" Width="100px">
                    <Template Context="user">
                        <RadzenButton Icon="login" ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.Small" 
                                      Click="@(() => Login(user.Id))" 
                                      MouseEnter="@(args => ShowTooltip(args, "Увійти як цей студент"))" />
                    </Template>
                </RadzenDataGridColumn>
            </Columns>
        </RadzenDataGrid>
    </RadzenCard>
</div>

@code {
    List<User> users = new();

    protected override async Task OnInitializedAsync()
    {
        // Завантажуємо більше юзерів, щоб перевірити пагінацію
        users = await Db.Users.OrderBy(u => u.FullName).Take(50).ToListAsync();
    }

    void Login(Guid userId)
    {
        Nav.NavigateTo($"/exam/{userId}");
    }
    
    void ShowTooltip(ElementReference elementReference, string text)
    {
        // Опціонально, для краси
    }
}