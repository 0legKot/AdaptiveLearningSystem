@page "/teacher/mining"
@using AdaptiveTesting.Domain.Interfaces
@using AdaptiveTesting.Infrastructure.Persistence
@using Microsoft.EntityFrameworkCore
@inject AppDbContext Db
@inject IMlService MlService
@inject NavigationManager Nav
@rendermode InteractiveServer

<div class="container mt-4">
    <div class="d-flex align-items-center mb-4">
        <RadzenButton Icon="arrow_back" ButtonStyle="ButtonStyle.Light" Click="@(() => Nav.NavigateTo("/teacher/monitor"))" Class="me-3" />
        <div>
            <h2 class="mb-0">🧠 Data Mining: Пошук прихованих зв'язків</h2>
            <small class="text-muted">Використання алгоритму <strong>Apriori</strong> (Metric: Lift > 1.1).</small>
        </div>
    </div>

    @if (isLoading) {
        <div class="text-center mt-5">
            <RadzenProgressBar Mode="ProgressBarMode.Indeterminate" />
            <p class="mt-2">ML-модель аналізує історію відповідей...</p>
        </div>
    } else if (rules == null || !rules.Any()) {
        <RadzenCard class="text-center p-5">
            <RadzenIcon Icon="search_off" Style="font-size: 4rem" class="text-muted mb-3" />
            <h4>Асоціацій не знайдено</h4>
            <p>Спробуйте накопичити більше даних (пройдіть більше тестів).</p>
        </RadzenCard>
    } else {
        <div class="row">
            <div class="col-md-12">
                <RadzenCard>
                    <RadzenDataGrid Data="@rules" TItem="MiningRule" AllowSorting="true" ColumnWidth="200px">
                        <Columns>
                            <RadzenDataGridColumn Property="rule" Title="Правило (Якщо -> То)" Width="400px">
                                <Template Context="r">
                                    <span style="font-size: 1.1em; font-weight: 500;">@r.rule</span>
                                </Template>
                            </RadzenDataGridColumn>

                            <RadzenDataGridColumn Property="lift" Title="Lift (Сила)" Width="120px">
                                <Template Context="r">
                                    <RadzenBadge BadgeStyle="BadgeStyle.Secondary" Text="@r.lift.ToString("F2")" />
                                </Template>
                            </RadzenDataGridColumn>

                            <RadzenDataGridColumn Property="confidence" Title="Confidence" Width="150px">
                                <Template Context="r">
                                    <div class="d-flex align-items-center">
                                        <RadzenProgressBar Value="@(r.confidence * 100)" Max="100" ShowValue="false" Style="height: 10px; width: 60px; margin-right: 10px" />
                                        <span>@((r.confidence * 100).ToString("F0"))%</span>
                                    </div>
                                </Template>
                            </RadzenDataGridColumn>

                            <RadzenDataGridColumn Property="support" Title="Support" Width="100px">
                                <Template Context="r">
                                    @((r.support * 100).ToString("F1"))%
                                </Template>
                            </RadzenDataGridColumn>
                        </Columns>
                    </RadzenDataGrid>
                </RadzenCard>
            </div>
        </div>

        <div class="alert alert-info mt-4">
            <strong>Як читати метрики:</strong>
            <ul>
                <li><strong>Lift > 1:</strong> Позитивна кореляція (теми пов'язані).</li>
                <li><strong>Confidence:</strong> Ймовірність того, що правило спрацює.</li>
                <li><strong>Support:</strong> Як часто це трапляється серед усіх студентів.</li>
            </ul>
        </div>
    }
</div>

@code {
    private bool isLoading = true;
    private List<MiningRule>? rules;

    protected override async Task OnInitializedAsync() {
        try {
            var rawHistory = await Db.TestSessions
                .Include(s => s.Answers).ThenInclude(a => a.Question)
                .Where(s => s.FinishedAt != null)
                .ToListAsync();

            var historyItems = rawHistory.Select(s => new StudentHistoryItem(
                s.UserId.ToString(),
                s.Answers.Where(a => !a.IsCorrect)
                         .Select(a => a.Question.Topic)
                         .Where(t => !string.IsNullOrEmpty(t))
                         .Distinct()
                         .ToList()
            )).ToList();

            if (historyItems.Any()) {
                rules = await MlService.GetMiningRulesAsync(historyItems);
            }
        } catch (Exception ex) {
            Console.WriteLine($"Error: {ex.Message}");
        } finally {
            isLoading = false;
        }
    }
}