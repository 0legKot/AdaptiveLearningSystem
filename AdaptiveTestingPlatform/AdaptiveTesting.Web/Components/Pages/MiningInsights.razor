@page "/teacher/mining"
@using AdaptiveTesting.Domain.Interfaces
@using AdaptiveTesting.Infrastructure.Persistence
@using Microsoft.EntityFrameworkCore
@inject AppDbContext Db
@inject IMlService MlService
@inject NavigationManager Nav
@inject TooltipService TooltipService
@rendermode InteractiveServer

<div class="container mt-4">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h2 class="mb-0">🧠 Приховані закономірності (AI Insights)</h2>
            <small class="text-muted">Аналіз типових ланцюжків помилок студентів.</small>
        </div>
        <div>
            @if (rules != null) {
                <RadzenBadge BadgeStyle="BadgeStyle.Info" Text="@($"Знайдено важливих правил: {rules.Count}")" class="fs-5" />
            }
        </div>
    </div>

    @if (isLoading) {
        <div class="text-center mt-5">
            <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem;"></div>
            <p class="mt-3 text-muted">Аналізуємо історію тестування...</p>
        </div>
    } else if (rules == null || !rules.Any()) {
        <RadzenCard class="text-center p-5 bg-light border-0">
            <RadzenIcon Icon="done_all" Style="font-size: 4rem; color: #28a745;" class="mb-3" />
            <h4 class="text-muted">Явних патернів помилок не виявлено</h4>
            <p>Студенти помиляються хаотично, стійких залежностей поки немає.</p>
        </RadzenCard>
    } else {
        <div class="row">
            @foreach (var rule in rules) {
                var parts = rule.rule.Split("->");
                var fromTopic = parts.Length > 0 ? parts[0].Trim() : "?";
                var toTopic = parts.Length > 1 ? parts[1].Trim() : "?";

                string strengthLabel;
                string strengthStyle;

                if (rule.lift > 2.0) {
                    strengthLabel = "🔥 Критичний зв'язок";
                    strengthStyle = "border-danger border-2";
                } else if (rule.lift > 1.5) {
                    strengthLabel = "⚡ Сильний зв'язок";
                    strengthStyle = "border-warning border-2";
                } else {
                    strengthLabel = "🔗 Помірний зв'язок";
                    strengthStyle = "border-info";
                }

                <div class="col-md-6 col-lg-4 mb-4">
                    <RadzenCard class="@($"h-100 shadow-sm {strengthStyle}")" Style="position: relative;">

                        <div class="position-absolute top-0 end-0 m-2">
                            <RadzenBadge BadgeStyle="BadgeStyle.Light" Text="@strengthLabel" class="text-dark fw-normal" />
                        </div>

                        <div class="mt-4 d-flex align-items-center justify-content-center mb-3 text-center">
                            <div class="fw-bold p-2 bg-light rounded border" style="min-width: 90px;">@fromTopic</div>
                            <RadzenIcon Icon="double_arrow" class="mx-2 text-muted" />
                            <div class="fw-bold p-2 bg-danger-subtle rounded border border-danger text-danger" style="min-width: 90px;">@toTopic</div>
                        </div>

                        <hr class="my-3 opacity-25" />

                        <div class="d-flex justify-content-around text-center">
                            <div title="Ймовірність того, що правило справдиться">
                                <div class="small text-muted text-uppercase">Ймовірність</div>
                                <div class="fw-bold text-primary fs-4">
                                    @((rule.confidence * 100).ToString("F0"))%
                                </div>
                            </div>

                            <div title="У скільки разів частіше це стається, ніж просто випадково">
                                <div class="small text-muted text-uppercase">Сила (Lift)</div>
                                <div class="fw-bold text-dark fs-4">
                                    @rule.lift.ToString("F1")x
                                </div>
                            </div>
                        </div>

                        <div class="mt-3 p-2 bg-light rounded small text-center text-muted">
                            "Студент, який не знає <strong>@fromTopic</strong>, майже гарантовано провалить <strong>@toTopic</strong>."
                        </div>

                    </RadzenCard>
                </div>
            }
        </div>
    }
</div>

@code {
    private bool isLoading = true;
    private List<MiningRule>? rules;

    protected override async Task OnInitializedAsync() {
        try {
            var rawHistory = await Db.TestSessions
                .Include(s => s.Answers).ThenInclude(a => a.Question)
                .Where(s => s.FinishedAt != null)
                .ToListAsync();

            var historyItems = rawHistory.Select(s => new StudentHistoryItem(
                s.UserId.ToString(),
                s.Answers.Where(a => !a.IsCorrect)
                         .Select(a => a.Question.Topic)
                         .Where(t => !string.IsNullOrEmpty(t))
                         .Distinct()
                         .ToList()
            )).ToList();

            if (historyItems.Any()) {
                var rawRules = await MlService.GetMiningRulesAsync(historyItems);

                // ФІЛЬТРАЦІЯ: Прибираємо сміття, залишаємо тільки значущі правила
                // Confidence > 50% (частіше так, ніж ні)
                // Lift > 1.2 (не випадковість)
                rules = rawRules
                    .Where(r => r.confidence > 0.5 && r.lift > 1.2)
                    .OrderByDescending(r => r.lift)
                    .ToList();
            }
        } catch (Exception ex) {
            Console.WriteLine($"Error: {ex.Message}");
        } finally {
            isLoading = false;
        }
    }
}