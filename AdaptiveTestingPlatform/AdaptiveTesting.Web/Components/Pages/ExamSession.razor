@page "/exam/{UserId:guid}"
@using AdaptiveTesting.Domain.Entities
@using AdaptiveTesting.Infrastructure.Services
@using AdaptiveTesting.Infrastructure.Persistence
@using Microsoft.EntityFrameworkCore
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject TestEngineService Engine
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject AppDbContext Db

<div class="container mt-4" style="max-width: 900px;">
    @if (currentQuestion == null) {
        if (isFinished) {
            <RadzenCard class="text-center p-5 shadow-lg border-0 bg-light">
                <div class="mb-4">
                    <RadzenIcon Icon="emoji_events" Style="font-size: 6rem; color: #f59e0b;" />
                </div>
                <h2 class="text-success fw-bold">Тест завершено!</h2>
                <p class="lead text-muted">ШІ проаналізував вашу траєкторію. Час переглянути результати.</p>
                <div class="mt-5">
                    <RadzenButton Text="Перейти до Аналітики" Click="@(() => Nav.NavigateTo($"/dashboard/{UserId}"))"
                                  ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.Large" Icon="analytics" Class="px-5" />
                </div>
            </RadzenCard>
        } else {
            <div class="text-center mt-5">
                <div class="spinner-border text-primary" style="width: 3rem; height: 3rem;" role="status"></div>
                <h4 class="mt-4 text-primary">AI Adaptive Engine</h4>
                <p class="text-muted">Аналізуємо вашу відповідь та підбираємо оптимальне питання...</p>
            </div>
        }
    } else {
        <div class="row">
            <div class="col-md-8">
                <RadzenCard class="shadow-sm mb-3">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <div class="d-flex align-items-center gap-2">
                            <span class="text-muted small text-uppercase fw-bold">Тема:</span>
                            <RadzenBadge BadgeStyle="BadgeStyle.Light" Text="@currentQuestion.Topic" class="text-dark border" />
                        </div>

                        <div>
                            @if (currentQuestion.Difficulty <= -1.0) {
                                <RadzenBadge BadgeStyle="BadgeStyle.Success" Text="EASY" />
                            } else if (currentQuestion.Difficulty >= 1.0) {
                                <RadzenBadge BadgeStyle="BadgeStyle.Danger" Text="HARD" />
                            } else {
                                <RadzenBadge BadgeStyle="BadgeStyle.Warning" Text="MEDIUM" />
                            }
                        </div>
                    </div>

                    <hr class="my-3 opacity-25" />

                    <h4 class="mb-4 lh-base">@((MarkupString)currentQuestion.Text)</h4>

                    <div class="mb-4 d-grid gap-2">
                        @for (int i = 0; i < options.Count; i++) {
                            var idx = i;
                            string baseClass = "p-3 border rounded d-flex align-items-center cursor-pointer transition-all";
                            string colorClass = "bg-white border-light-subtle hover-shadow";

                            if (isAnswered) {
                                if (idx == currentQuestion.CorrectOptionIndex) colorClass = "bg-success-subtle border-success text-success-emphasis fw-bold";
                                else if (idx == selectedOption) colorClass = "bg-danger-subtle border-danger text-danger-emphasis";
                                else colorClass = "bg-light text-muted opacity-50";
                            } else if (selectedOption == idx) {
                                colorClass = "bg-primary-subtle border-primary text-primary-emphasis fw-bold shadow-sm";
                            }

                            <div class="@($"{baseClass} {colorClass}")" @onclick="() => SelectOption(idx)" style="transition: all 0.2s;">
                                <div class="flex-grow-1">
                                    @options[idx]
                                </div>
                                @if (isAnswered && idx == currentQuestion.CorrectOptionIndex) {
                                    <RadzenIcon Icon="check_circle" />
                                } else if (isAnswered && idx == selectedOption) {
                                    <RadzenIcon Icon="cancel" />
                                }
                            </div>
                        }
                    </div>

                    <div class="d-flex justify-content-end mt-4">
                        @if (!isAnswered) {
                            <RadzenButton Text="Відповісти" Click="SubmitAnswer" Disabled="@(selectedOption == -1)" IsBusy="@isBusy" Icon="send" ButtonStyle="ButtonStyle.Primary" class="px-4" />
                        } else {
                            <RadzenButton Text="Наступне питання" Click="LoadNextQuestionData" ButtonStyle="ButtonStyle.Secondary" Icon="arrow_forward" class="px-4" />
                        }
                    </div>
                </RadzenCard>
            </div>

            <div class="col-md-4">
                <RadzenCard class="bg-light border-0">
                    <h6 class="text-muted text-uppercase small fw-bold mb-3">Ваш прогрес</h6>

                    <div class="mb-4">
                        <div class="d-flex justify-content-between small mb-1">
                            <span>Поточний рівень (@currentQuestion.Topic)</span>
                            <span class="fw-bold">@((currentThetaScore * 100).ToString("F0"))%</span>
                        </div>
                        <RadzenProgressBar Value="@(currentThetaScore * 100)" Max="100" ShowValue="false" Style="height: 8px" />
                        <small class="text-muted" style="font-size: 0.75rem;">
                            Оцінка BKT оновлюється після кожного питання.
                        </small>
                    </div>

                    <div class="alert alert-info d-flex align-items-start p-2">
                        <RadzenIcon Icon="psychology" class="me-2 fs-4" />
                        <div class="small lh-sm">
                            Система адаптується до вас. Якщо ви відповідаєте правильно, наступне питання може бути складнішим.
                        </div>
                    </div>
                </RadzenCard>
            </div>
        </div>
    }
</div>

<style>
    .hover-shadow:hover {
        box-shadow: 0 .5rem 1rem rgba(0,0,0,.05) !important;
        border-color: var(--rz-primary-light) !important;
    }

    .cursor-pointer {
        cursor: pointer;
    }
</style>

<script>
    window.examTracker = {
        startTime: Date.now(),
        focusLostCount: 0,
        startTimer: function() {
            this.startTime = Date.now();
            this.focusLostCount = 0;
            window.onblur = () => { this.focusLostCount++; };
        },
        getMetrics: function() {
            window.onblur = null;
            return {
                timeSpent: Date.now() - this.startTime,
                focusLost: this.focusLostCount
            };
        }
    };
</script>

@code {
    [Parameter] public Guid UserId { get; set; }

    private TestSession? session;
    private Question? currentQuestion;
    private List<string> options = new();
    private int selectedOption = -1;
    private bool isFinished = false;
    private bool isBusy = false;
    private bool isAnswered = false;
    private double currentThetaScore = 0.5; // Дефолт 50%

    protected override async Task OnInitializedAsync() {
        session = await Engine.StartSessionAsync(UserId);
        await LoadNextQuestionData();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender) {
        if (firstRender && currentQuestion != null) await StartTimer();
    }

    private async Task LoadNextQuestionData() {
        isAnswered = false;
        selectedOption = -1;
        currentQuestion = await Engine.GetNextQuestionAsync(UserId, session.Id);

        if (currentQuestion == null) {
            isFinished = true;
            await Engine.FinishSessionAsync(session.Id);
        } else {
            options = System.Text.Json.JsonSerializer.Deserialize<List<string>>(currentQuestion.OptionsJson) ?? new();
            await UpdateCurrentScoreDisplay();
            await StartTimer();
        }
    }

    private async Task UpdateCurrentScoreDisplay() {
        // Отримуємо поточний скіл студента по цій темі з БД для відображення
        var state = await Db.UserTopicStates
            .AsNoTracking()
            .FirstOrDefaultAsync(s => s.UserId == UserId && s.TopicName == currentQuestion.Topic);

        if (state != null) {
            // Нормалізуємо Theta (-3..3) в 0..1
            double sigmoid = 1.0 / (1.0 + Math.Exp(-state.AbilityTheta));
            currentThetaScore = sigmoid;
        }
    }

    private void SelectOption(int index) { if (!isAnswered) selectedOption = index; }

    private async Task SubmitAnswer() {
        isBusy = true;
        var metrics = await JS.InvokeAsync<ExamMetrics>("examTracker.getMetrics");
        int time = (int)metrics.timeSpent;
        if (metrics.timeSpent < 0 || metrics.timeSpent > int.MaxValue) time = 1000;

        await Engine.SubmitAnswerAsync(session.Id, currentQuestion.Id, selectedOption, time, metrics.focusLost);
        isAnswered = true;
        isBusy = false;

        // Оновлюємо скіл одразу, щоб показати результат
        await UpdateCurrentScoreDisplay();
    }

    private async Task StartTimer() { try { await JS.InvokeVoidAsync("examTracker.startTimer"); } catch { } }

    public class ExamMetrics { public double timeSpent { get; set; } public int focusLost { get; set; } }
}