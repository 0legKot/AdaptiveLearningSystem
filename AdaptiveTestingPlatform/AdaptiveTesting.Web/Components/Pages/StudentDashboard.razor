@page "/dashboard/{UserId:guid}"
@using AdaptiveTesting.Domain.Interfaces
@using AdaptiveTesting.Infrastructure.Services
@using Radzen
@using Radzen.Blazor
@inject AnalyticsService Analytics
@inject NavigationManager Nav
@rendermode InteractiveServer
@inject IMlService MlService

<div class="container mt-4">
    @if (stats == null) {
        <RadzenProgressBar Mode="ProgressBarMode.Indeterminate" />
    } else {
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h3>📊 Аналітика: @stats.StudentName</h3>
            <RadzenButton Text="Пройти ще один тест" Icon="add_task" Click="@(() => Nav.NavigateTo($"/exam/{UserId}"))" />
        </div>

        <div class="row mb-4">
            <div class="col-12">
                <RadzenCard Variant="Variant.Filled" Class="bg-primary-subtle">
                    <div class="d-flex align-items-center justify-content-between px-4">
                        <div>
                            <h6 class="text-primary mb-1">AI Прогноз фінальної оцінки (Linear Regression)</h6>
                            <h1 class="display-3 text-primary fw-bold mb-0">@stats.PredictedScore</h1>
                            <small class="text-muted">Розраховано на основі динаміки ваших відповідей, часу реакції та концентрації.</small>
                        </div>
                        <RadzenArcGauge Style="width: 200px; height: 200px;">
                            <RadzenArcGaugeScale Step="20" Min="0" Max="100" TickPosition="GaugeTickPosition.Inside" Radius="1.5">
                                <RadzenArcGaugeScaleValue Value="@stats.PredictedScore" ShowValue="false" Fill="#4f46e5" />
                            </RadzenArcGaugeScale>
                        </RadzenArcGauge>
                    </div>
                </RadzenCard>
            </div>
        </div>

        <div class="row">
            <div class="col-md-7 mb-4">
                <RadzenCard>
                    <h4 class="mb-3">Карта навичок (Skill Map)</h4>
                    @if (stats.Skills.Any()) {
                        <RadzenChart Style="height: 400px">
                            <RadzenBarSeries Data="@stats.Skills"
                                             CategoryProperty="Topic"
                                             Title="Рівень знань (%)"
                                             ValueProperty="Score"
                                             Fill="#4f46e5">
                                <RadzenSeriesDataLabels Visible="true" />
                            </RadzenBarSeries>
                            <RadzenValueAxis Min="0" Max="100" Step="20">
                                <RadzenGridLines Visible="true" />
                            </RadzenValueAxis>
                            <RadzenCategoryAxis Padding="0.2" />
                            <RadzenLegend Visible="false" />
                        </RadzenChart>
                    } else {
                        <p class="text-muted">Немає даних. Пройдіть тест, щоб побачити графік.</p>
                    }
                </RadzenCard>
            </div>

            <div class="col-md-5 mb-4">
                <RadzenCard class="h-100">
                    <h4 class="mb-3">Профіль ML</h4>

                    <div class="alert alert-info">
                        <strong>AI Cluster (K-Means):</strong>
                        @if (stats.ClusterLabel == 0) {
                            <span>Підозріла активність (Cheater pattern)</span>
                        } else if (stats.ClusterLabel == 1) {

                            <span>Початківець (Junior pattern)</span>
                        } else if (stats.ClusterLabel == 2) {

                            <span>Експерт (Senior pattern)</span>
                        } else {

                            <span>Не визначено</span>
                        }
                    </div>

                    <h5 class="mt-4">Останні сесії (Isolation Forest)</h5>
                    <ul class="list-group">
                        @foreach (var session in stats.RecentSessions) {
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                <span>@session.Date.ToString("g")</span>
                                @if (session.IsSuspicious) {
                                    <RadzenBadge BadgeStyle="BadgeStyle.Danger" Text="Anomaly Detected" />
                                } else {
                                    <RadzenBadge BadgeStyle="BadgeStyle.Success" Text="OK" />
                                }
                            </li>
                        }
                    </ul>
                </RadzenCard>
            </div>
        </div>
        <div class="row mb-4">
            <div class="col-12">
                <RadzenCard>
                    <h5 class="mb-3">Що впливає на вашу оцінку? (Random Forest Analysis)</h5>
                    <div class="row">
                        <div class="col-md-4 d-flex align-items-center justify-content-center">
                            <div class="text-muted text-center">
                                <p>Ми використали алгоритм <strong>Random Forest Regressor</strong>, щоб визначити вагу кожного фактора успішності.</p>
                                <p class="small">Аналіз показує, що найбільший вплив має <span class="fw-bold text-primary">@GetTopFactor()</span>.</p>
                            </div>
                        </div>
                        <div class="col-md-8">
                            @if (stats.FeatureImportance.Any()) {
                                <RadzenChart Style="height: 250px">
                                    <RadzenPieSeries Data="@stats.FeatureImportance" CategoryProperty="Key" ValueProperty="Value" Title="Важливість" Fills="@(new[] { "#4f46e5", "#10b981", "#f59e0b" })">
                                        <RadzenSeriesDataLabels Visible="true" />
                                    </RadzenPieSeries>
                                    <RadzenLegend Position="LegendPosition.Right" />
                                </RadzenChart>
                            } else {
                                <RadzenProgressBar Mode="ProgressBarMode.Indeterminate" />
                            }
                        </div>
                    </div>
                </RadzenCard>
            </div>
        </div>

        <div class="row">
            <div class="col-12">
                <h4 class="mb-3 ms-1">💡 Персональні рекомендації (NLP & Rule-Based)</h4>
            </div>

            @foreach (var rec in stats.Recommendations) {
                // Парсимо тип рекомендації для стилізації
                var isWarning = rec.Contains("⚠️");
                var isSuccess = rec.Contains("✅");
                var icon = isWarning ? "warning" : (isSuccess ? "check_circle" : "info");
                var borderClass = isWarning ? "border-warning" : (isSuccess ? "border-success" : "border-info");
                var bgClass = isWarning ? "bg-warning-subtle" : (isSuccess ? "bg-success-subtle" : "bg-info-subtle");

                // Витягуємо тему (всередині **...**)
                var topic = System.Text.RegularExpressions.Regex.Match(rec, @"\*\*(.*?)\*\*").Groups[1].Value;
                if (string.IsNullOrEmpty(topic)) topic = "Загальні поради";

                <div class="col-md-4 mb-3">
                    <RadzenCard Class="@($"h-100 {borderClass} border-top-0 border-end-0 border-bottom-0 border-4 shadow-sm")">
                        <div class="d-flex align-items-start">
                            <RadzenIcon Icon="@icon" Class="me-3 fs-3" Style="@(isWarning ? "color: #d97706" : (isSuccess ? "color: #059669" : "color: #0ea5e9"))" />
                            <div>
                                <h6 class="fw-bold mb-1">@topic</h6>
                                <p class="text-muted small mb-3">
                                    @((MarkupString)CleanText(rec))
                                </p>
                                @if (!isSuccess) {
                                    <RadzenButton Text="Вивчити тему" Size="ButtonSize.ExtraSmall" ButtonStyle="ButtonStyle.Light" Class="w-100" />
                                }
                            </div>
                        </div>
                    </RadzenCard>
                </div>
            }
        </div>

    }
</div>

@code {
    [Parameter] public Guid UserId { get; set; }
    Dictionary<string, double> factors = new();
    private StudentDashboardDto? stats;

    protected override async Task OnInitializedAsync() {
        stats = await Analytics.GetStudentStatsAsync(UserId);
    }

    private string MarkdownToHtml(string text) {
        return text.Replace("**", "<strong>").Replace("⚠️", "<span class='text-danger'>⚠️</span>").Replace("✅", "<span class='text-success'>✅</span>");
    }

    string GetTopFactor() {
        if (stats?.FeatureImportance == null || !stats.FeatureImportance.Any()) return "Невідомий фактор";

        return stats.FeatureImportance.OrderByDescending(x => x.Value).FirstOrDefault().Key switch {
            "TimeSpent" => "Час на відповідь",
            "FocusLost" => "Втрата концентрації",
            "CurrentScore" => "Поточна успішність",
            _ => "Інше"
        };
    }

    // Очищає текст від маркдауну для виводу в картку
    string CleanText(string text) {
        return text.Replace("**", "").Replace("⚠️", "").Replace("✅", "").Replace("ℹ️", "").Trim();
    }
}